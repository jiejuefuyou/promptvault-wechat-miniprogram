/* app.wxss — global styles, dark theme matching iOS / Web edition */

page {
  background: #0a0a0f;
  color: #e6e6f0;
  font: 28rpx/1.6 -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  min-height: 100vh;
}

view, text { box-sizing: border-box; }

.muted { color: #8a8a9a; }
.accent { color: #9b6cf0; }
.good { color: #4ade80; }
.warn { color: #ffb547; }

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  margin: 4rpx 6rpx 4rpx 0;
  border-radius: 999rpx;
  background: #1f1f2e;
  color: #8a8a9a;
  font-size: 22rpx;
}
.tag.active {
  background: rgba(108,75,224,0.25);
  color: #9b6cf0;
}

.btn {
  padding: 18rpx 32rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #6c4be0, #9b6cf0);
  color: white;
  text-align: center;
  font-weight: 600;
  font-size: 28rpx;
}
.btn[disabled] { opacity: 0.5; }
.btn.secondary {
  background: #12121a;
  border: 1rpx solid #1f1f2e;
  color: #e6e6f0;
}

.card {
  background: #12121a;
  border: 1rpx solid #1f1f2e;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
