.container { padding: 32rpx 28rpx 100rpx; }

.hero {
  text-align: center;
  padding: 40rpx 0 32rpx;
  border-bottom: 1rpx solid #1f1f2e;
  margin-bottom: 32rpx;
}
.logo {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}
.app-name {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #6c4be0, #c084fc);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-bottom: 8rpx;
}
.app-subtitle {
  font-size: 24rpx;
}

.stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #12121a;
  border-radius: 16rpx;
  border: 1rpx solid #1f1f2e;
}
.stat-item {
  text-align: center;
  flex: 1;
}
.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #c084fc;
}
.stat-label {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.section {
  margin-bottom: 32rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e6e6f0;
  margin-bottom: 12rpx;
}
.section-body {
  font-size: 28rpx;
  line-height: 1.8;
  color: #c0c0d0;
}

.action-section {
  background: #12121a;
  border: 1rpx solid #1f1f2e;
  border-radius: 16rpx;
  padding: 8rpx 0;
  margin-bottom: 32rpx;
}
.action-section .section-title {
  padding: 16rpx 24rpx;
  margin-bottom: 0;
}
.action-row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-top: 1rpx solid #1f1f2e;
}
.action-row:active {
  background: rgba(108,75,224,0.08);
}
.action-icon {
  font-size: 40rpx;
  margin-right: 18rpx;
  width: 60rpx;
  text-align: center;
}
.action-text {
  flex: 1;
}
.action-title {
  font-size: 28rpx;
  color: #e6e6f0;
  margin-bottom: 4rpx;
}
.action-sub {
  font-size: 22rpx;
}
.action-arrow {
  color: #4a4a5a;
  font-size: 36rpx;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1.8;
}
