.container { padding: 32rpx 28rpx 100rpx; }

/* === 头部 === */
.header {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #1f1f2e;
}

.meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.date { font-size: 24rpx; }
.badge {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}
.badge.newsletter { background: rgba(255,181,71,0.15); color: #ffb547; }
.badge.deep-dive { background: rgba(108,75,224,0.18); color: #c084fc; }

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #e6e6f0;
  line-height: 1.35;
  margin-bottom: 16rpx;
}

.summary {
  font-size: 28rpx;
  line-height: 1.6;
  color: #c084fc;
  padding: 16rpx 20rpx;
  background: rgba(108,75,224,0.08);
  border-left: 4rpx solid #6c4be0;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.tags { margin-top: 8rpx; }

/* === markdown body === */
.article-body { line-height: 1.8; }

.md-h1 {
  font-size: 40rpx;
  font-weight: 700;
  color: #e6e6f0;
  margin: 40rpx 0 16rpx;
  line-height: 1.4;
}
.md-h2 {
  font-size: 36rpx;
  font-weight: 700;
  color: #e6e6f0;
  margin: 36rpx 0 14rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #1f1f2e;
  line-height: 1.4;
}
.md-h3 {
  font-size: 30rpx;
  font-weight: 600;
  color: #c084fc;
  margin: 28rpx 0 12rpx;
  line-height: 1.4;
}

.md-p {
  font-size: 28rpx;
  color: #e6e6f0;
  margin-bottom: 18rpx;
  line-height: 1.8;
  word-wrap: break-word;
}

.md-quote {
  font-size: 26rpx;
  color: #8a8a9a;
  background: #12121a;
  border-left: 4rpx solid #6c4be0;
  padding: 16rpx 20rpx;
  margin: 16rpx 0;
  border-radius: 6rpx;
  line-height: 1.6;
}

.md-code {
  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 24rpx;
  background: #0a0a0f;
  border: 1rpx solid #1f1f2e;
  color: #c084fc;
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  margin: 16rpx 0;
  white-space: pre;
  overflow-x: auto;
  line-height: 1.6;
}

.md-hr {
  height: 1rpx;
  background: #1f1f2e;
  margin: 32rpx 0;
}

.md-table-row {
  font-family: ui-monospace, monospace;
  font-size: 22rpx;
  color: #e6e6f0;
  background: #12121a;
  padding: 8rpx 12rpx;
  border-bottom: 1rpx solid #1f1f2e;
  white-space: pre;
  overflow-x: auto;
}

.footer {
  margin-top: 60rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #1f1f2e;
  text-align: center;
}
.footer-text { font-size: 22rpx; }
