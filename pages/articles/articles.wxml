<view class="container">

  <view class="header">
    <view class="title">AI 新鲜事 ☕</view>
    <view class="subtitle muted">{{articles.length}} 篇看完不亏 · 喝杯咖啡的功夫</view>
  </view>

  <!-- 分类条 -->
  <scroll-view scroll-x class="cat-bar" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="cat-list">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="cat-item {{activeCat === item.id ? 'active' : ''}}"
        bindtap="onCatTap"
        data-id="{{item.id}}"
      >
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 文章列表 -->
  <view class="article-list">
    <view
      wx:for="{{filtered}}"
      wx:key="id"
      class="card article-item"
      bindtap="onArticleTap"
      data-id="{{item.id}}"
    >
      <view class="article-meta">
        <text class="article-date muted">{{item.date}}</text>
        <text wx:if="{{item.type === 'newsletter'}}" class="article-badge newsletter">📰 周报</text>
        <text wx:elif="{{item.type === 'deep-dive'}}" class="article-badge deep-dive">💡 干货</text>
      </view>
      <view class="article-title">{{item.title}}</view>
      <view class="article-summary muted">{{item.summary}}</view>
      <view class="article-tags">
        <text wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" class="tag">{{t}}</text>
      </view>
    </view>

    <view wx:if="{{filtered.length === 0}}" class="empty">
      <view class="empty-icon">📭</view>
      <view class="empty-text">这分类还没货呢～</view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-text muted">
      🗓 每周三早 8 点更新一条新鲜事
    </view>
    <view class="footer-text muted" style="margin-top: 8rpx;">
      想看完整版？jiejuefuyou.github.io 接邮件
    </view>
  </view>

</view>
