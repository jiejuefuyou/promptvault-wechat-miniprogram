<view class="container">

  <view class="header">
    <view class="title">我自己的 prompt ✏️</view>
    <view class="subtitle muted">攒了 {{customPrompts.length}} 个，加更多走起</view>
  </view>

  <button class="btn add-btn" bindtap="onAddTap">+ 加一条新的 prompt</button>

  <view wx:if="{{customPrompts.length > 0}}" class="prompt-list">
    <view
      wx:for="{{customPrompts}}"
      wx:key="title"
      class="card prompt-item"
    >
      <view bindtap="onPromptTap" data-idx="{{index}}">
        <view class="prompt-title">{{item.title}}</view>
        <view class="prompt-preview muted">{{item.body}}</view>
        <view class="prompt-tags">
          <text wx:for="{{item.tags}}" wx:for-item="t" wx:key="*this" class="tag">{{t}}</text>
        </view>
      </view>
      <view class="card-actions">
        <text class="del-btn" bindtap="onDelete" data-title="{{item.title}}">🗑 删除</text>
      </view>
    </view>
  </view>

  <view wx:elif="{{!showAddDialog}}" class="empty">
    <view class="empty-icon">📝</view>
    <view class="empty-text">还没攒过自己的 prompt</view>
    <view class="empty-hint muted">用得多的提示词写一遍存这，下次不用再想</view>
  </view>

  <!-- 底部链接区 -->
  <view wx:if="{{!showAddDialog}}" class="footer-links">
    <view class="footer-link" bindtap="onGoAbout">
      <text class="link-icon">💜</text>
      <text class="link-text">关于这个小程序</text>
      <text class="link-arrow">›</text>
    </view>
    <view class="footer-link" bindtap="onGoPrivacy">
      <text class="link-icon">🔒</text>
      <text class="link-text">隐私说明 (我们什么都不收集)</text>
      <text class="link-arrow">›</text>
    </view>
  </view>

  <!-- Add dialog -->
  <view wx:if="{{showAddDialog}}" class="dialog-mask" catch:tap="onCancelAdd">
    <view class="dialog" catch:tap="onDialogStop">
      <view class="dialog-title">写一条新 prompt ✏️</view>

      <scroll-view scroll-y class="dialog-scroll">
        <view class="field-label">起个名 *</view>
        <input
          class="field-input"
          value="{{newTitle}}"
          bindinput="onTitleInput"
          placeholder="比如：写 SwiftUI todo demo"
          placeholder-class="placeholder-grey"
          confirm-type="next"
        />

        <view class="field-label">prompt 内容 *</view>
        <textarea
          class="field-textarea"
          value="{{newBody}}"
          bindinput="onBodyInput"
          placeholder="比如：用 SwiftUI 写一个 [platform] 的 [feature] demo，不要外部依赖"
          placeholder-class="placeholder-grey"
          auto-height
          maxlength="-1"
          show-confirm-bar="{{false}}"
        />
        <view class="field-hint muted">💡 想留空让用户填？用双花括号包变量名，比如 platform、feature</view>

        <view class="field-label">贴标签 (可不填)</view>
        <input
          class="field-input"
          value="{{newTags}}"
          bindinput="onTagsInput"
          placeholder="比如：iOS, SwiftUI, Demo"
          placeholder-class="placeholder-grey"
        />
      </scroll-view>

      <view class="dialog-actions">
        <view class="dialog-btn secondary" catch:tap="onCancelAdd">不存了</view>
        <view class="dialog-btn" catch:tap="onSavePrompt">存下！</view>
      </view>
    </view>
  </view>

</view>
