.container { padding: 32rpx 24rpx 100rpx; }

.header { margin-bottom: 24rpx; }
.title { font-size: 48rpx; font-weight: 700; color: #e6e6f0; }
.subtitle { font-size: 24rpx; margin-top: 8rpx; }

.add-btn { margin-bottom: 24rpx; width: 100%; }

.prompt-item { position: relative; }
.prompt-title { font-size: 30rpx; font-weight: 600; color: #e6e6f0; margin-bottom: 8rpx; }
.prompt-preview { font-size: 24rpx; line-height: 1.4; margin-bottom: 12rpx; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.prompt-tags { margin-top: 4rpx; }

.card-actions { margin-top: 16rpx; padding-top: 12rpx; border-top: 1rpx solid #1f1f2e; text-align: right; }
.del-btn { font-size: 24rpx; color: #ff6b6b; padding: 8rpx 16rpx; }

.empty { text-align: center; padding: 200rpx 0; }
.empty-icon { font-size: 100rpx; color: #1f1f2e; line-height: 1; }
.empty-text { font-size: 30rpx; color: #e6e6f0; margin-top: 24rpx; }
.empty-hint { font-size: 24rpx; margin-top: 12rpx; }

/* Dialog */
.dialog-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex; align-items: center; justify-content: center;
  z-index: 100;
}
.dialog {
  width: 80%; max-width: 600rpx;
  background: #12121a; border: 1rpx solid #1f1f2e; border-radius: 16rpx;
  padding: 32rpx 28rpx;
}
.dialog-title { font-size: 32rpx; font-weight: 600; color: #e6e6f0; margin-bottom: 24rpx; text-align: center; }

.field-label { font-size: 24rpx; color: #8a8a9a; margin: 16rpx 0 6rpx; }
.field-input {
  width: 100%; background: #0a0a0f; border: 1rpx solid #1f1f2e; color: #e6e6f0;
  padding: 16rpx 18rpx; border-radius: 10rpx; font-size: 26rpx;
  box-sizing: border-box;
}
.field-textarea {
  width: 100%; background: #0a0a0f; border: 1rpx solid #1f1f2e; color: #e6e6f0;
  padding: 16rpx 18rpx; border-radius: 10rpx; font-size: 26rpx;
  min-height: 200rpx; box-sizing: border-box;
}
.placeholder-grey { color: #8a8a9a; }

.dialog-actions { margin-top: 32rpx; display: flex; justify-content: flex-end; }
.dialog-actions .btn { width: auto; padding: 14rpx 28rpx; }
