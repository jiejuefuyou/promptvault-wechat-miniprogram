/* pages/detail/detail.wxss */

.container {
  padding: 32rpx 24rpx 100rpx;
}

.header {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #1f1f2e;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e6e6f0;
  margin-bottom: 8rpx;
}

.desc-zh {
  font-size: 28rpx;
  color: #9b6cf0;
  margin-bottom: 12rpx;
  line-height: 1.5;
  padding: 12rpx 16rpx;
  background: rgba(108, 75, 224, 0.08);
  border-left: 3rpx solid #6c4be0;
  border-radius: 6rpx;
}

.tags {
  margin-top: 8rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #9b6cf0;
  margin-bottom: 16rpx;
  margin-top: 24rpx;
}

.vars-section {
  margin-bottom: 32rpx;
}

.var-row {
  margin-bottom: 16rpx;
}

.var-label {
  font-size: 24rpx;
  color: #8a8a9a;
  margin-bottom: 6rpx;
  font-family: ui-monospace, "SF Mono", Menlo, monospace;
}

.var-input {
  width: 100%;
  background: #12121a;
  border: 1rpx solid #1f1f2e;
  color: #e6e6f0;
  padding: 18rpx 22rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  min-height: 80rpx;
}

.var-placeholder {
  color: #8a8a9a;
}

.preview-section {
  margin-bottom: 32rpx;
}

.preview-body {
  background: #12121a;
  border: 1rpx solid #1f1f2e;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #e6e6f0;
  white-space: pre-wrap;
  word-wrap: break-word;
}

.actions {
  margin-top: 32rpx;
  margin-bottom: 24rpx;
}

.hint {
  font-size: 22rpx;
  text-align: center;
  margin-top: 24rpx;
  line-height: 1.5;
}
