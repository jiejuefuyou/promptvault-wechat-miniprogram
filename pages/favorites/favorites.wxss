.container { padding: 32rpx 24rpx 100rpx; }

.header { margin-bottom: 24rpx; }
.title { font-size: 48rpx; font-weight: 700; color: #e6e6f0; }
.subtitle { font-size: 24rpx; margin-top: 8rpx; }

.prompt-item { position: relative; }
.prompt-title { font-size: 30rpx; font-weight: 600; color: #e6e6f0; margin-bottom: 6rpx; }
.prompt-desc-zh { font-size: 24rpx; color: #9b6cf0; margin-bottom: 8rpx; line-height: 1.4; }
.prompt-preview { font-size: 24rpx; line-height: 1.4; margin-bottom: 12rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.prompt-tags { margin-top: 4rpx; }

.card-actions {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #1f1f2e;
  text-align: right;
}
.unfav-btn {
  font-size: 24rpx;
  color: #ffb547;
  padding: 8rpx 16rpx;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
}
.empty-icon { font-size: 80rpx; color: #1f1f2e; }
.empty-text { font-size: 30rpx; color: #e6e6f0; margin-top: 24rpx; }
.empty-hint { font-size: 24rpx; margin-top: 12rpx; }
.empty-action {
  display: inline-block;
  margin-top: 32rpx;
  padding: 16rpx 32rpx;
  width: auto;
}

.clear-all { text-align: center; padding: 32rpx 0 16rpx; }
.clear-btn { font-size: 24rpx; color: #8a8a9a; }
