<view class="container">

  <!-- Header -->
  <view class="header">
    <view class="title">提示词速查 ✨</view>
    <view class="subtitle muted">{{promptsAll.length}} 条 AI 提示词揣兜里，看完就能用</view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索标题 / 中文说明 / 内容 / 标签"
        placeholder-class="search-placeholder"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
        value="{{keyword}}"
      />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="onSearchClear">×</text>
    </view>
  </view>

  <!-- 搜索历史（搜索框聚焦但 keyword 空时显示） -->
  <view wx:if="{{searchHistory.length > 0 && !keyword}}" class="search-history">
    <view class="history-header">
      <text class="muted" style="font-size: 22rpx;">最近搜索</text>
      <text class="muted" style="font-size: 22rpx;" bindtap="onClearSearchHistory">清空</text>
    </view>
    <view class="history-tags">
      <text
        wx:for="{{searchHistory}}"
        wx:key="*this"
        class="tag"
        bindtap="onSearchHistoryTap"
        data-kw="{{item}}"
      >{{item}}</text>
    </view>
  </view>

  <!-- 8 大类 -->
  <scroll-view scroll-x class="cat-bar" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="cat-list">
      <view
        class="cat-item {{activeCategory === '' ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id=""
      >
        <text class="cat-icon">📋</text>
        <text class="cat-name">全部</text>
      </view>
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="cat-item {{activeCategory === item.id ? 'active' : ''}}"
        bindtap="onCategoryTap"
        data-id="{{item.id}}"
      >
        <text class="cat-icon">{{item.icon}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 子标签（当前 category 下）-->
  <scroll-view wx:if="{{availableTags.length > 0}}" scroll-x class="tag-bar" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="tag-list">
      <view
        wx:if="{{activeTag}}"
        class="tag active"
        bindtap="onTagTap"
        data-tag="{{activeTag}}"
      >× {{activeTag}}</view>
      <view
        wx:for="{{availableTags}}"
        wx:key="*this"
        class="tag {{activeTag === item ? 'active' : ''}}"
        bindtap="onTagTap"
        data-tag="{{item}}"
      >{{item}}</view>
    </view>
  </scroll-view>

  <!-- 工具栏：结果数 + 排序 + 视图切换 -->
  <view class="toolbar">
    <view class="result-meta muted">
      {{promptsFiltered.length}} 条
      <text wx:if="{{activeCategory || activeTag || keyword}}" class="clear-link" bindtap="onClearAll"> · 清除筛选</text>
    </view>
    <view class="toolbar-actions">
      <view class="tool-btn" bindtap="onSortToggle">
        ↕ {{sortBy === 'default' ? '默认' : sortBy === 'recent' ? '最近用过' : sortBy === 'favorite' ? '收藏优先' : '字母排序'}}
      </view>
      <view class="tool-btn" bindtap="onViewModeToggle">
        {{viewMode === 'card' ? '☰' : '▦'}}
      </view>
    </view>
  </view>

  <!-- 排序菜单（弹窗）-->
  <view wx:if="{{showSortMenu}}" class="sort-menu-mask" catch:tap="onSortToggle">
    <view class="sort-menu" catch:tap="onDialogStop">
      <view
        wx:for="{{sortOptions}}"
        wx:key="id"
        class="sort-item {{sortBy === item.id ? 'active' : ''}}"
        catch:tap="onSortSelect"
        data-id="{{item.id}}"
      >
        <text>{{item.label}}</text>
        <text wx:if="{{sortBy === item.id}}" class="check">✓</text>
      </view>
    </view>
  </view>

  <!-- Prompt 列表 -->
  <view class="prompt-list {{viewMode}}">
    <view
      wx:for="{{promptsFiltered}}"
      wx:key="title"
      class="card prompt-item"
    >
      <view
        class="fav-toggle {{favoriteSet[item.title] ? 'is-fav' : ''}}"
        catch:tap="onToggleFavorite"
        data-title="{{item.title}}"
      >{{favoriteSet[item.title] ? '★' : '☆'}}</view>

      <view bindtap="onPromptTap" data-idx="{{index}}" class="prompt-main">
        <view class="prompt-title">{{item.title}}</view>
        <view wx:if="{{item.desc_zh}}" class="prompt-desc-zh">{{item.desc_zh}}</view>
        <view wx:if="{{viewMode === 'card'}}" class="prompt-preview muted">{{item.body}}</view>
        <view wx:if="{{viewMode === 'card'}}" class="prompt-tags">
          <text
            wx:for="{{item.tags}}"
            wx:for-item="t"
            wx:key="*this"
            class="tag"
          >{{t}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{promptsFiltered.length === 0}}" class="empty muted">
      <view style="font-size: 80rpx; line-height: 1; margin-bottom: 16rpx;">🤔</view>
      <view>这个角落空空的呢</view>
      <view class="empty-hint" style="margin-top: 12rpx; font-size: 22rpx;">换个关键词试试看？</view>
      <view class="empty-action" bindtap="onClearAll" style="display: inline-block; margin-top: 20rpx; padding: 14rpx 28rpx; background: #6c4be0; color: white; border-radius: 10rpx;">回到首页 →</view>
    </view>
  </view>

  <!-- Footer -->
  <view class="footer">
    <view class="footer-text muted">
      🔒 完全离线，你输入的内容不会发任何地方
    </view>
    <view class="footer-text muted" style="margin-top: 12rpx;">
      还有 iOS / 网页 / Chrome / VSCode 4 个版本 ↗ jiejuefuyou.github.io
    </view>
  </view>

  <!-- Banner ad -->
  <ad
    wx:if="{{showBannerAd && bannerAdUnitId}}"
    unit-id="{{bannerAdUnitId}}"
    ad-type="banner"
    ad-theme="black"
  ></ad>

</view>
