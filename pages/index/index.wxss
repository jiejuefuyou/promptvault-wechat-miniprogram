/* pages/index/index.wxss */

.container {
  padding: 32rpx 24rpx 100rpx;
}

.header {
  margin-bottom: 32rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #6c4be0, #c084fc);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.subtitle {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.search-bar {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  background: #12121a;
  border: 1rpx solid #1f1f2e;
  color: #e6e6f0;
  padding: 22rpx 28rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.search-placeholder {
  color: #8a8a9a;
}

.tag-bar {
  margin-bottom: 16rpx;
  width: 100%;
  white-space: nowrap;
}

.tag-list {
  display: inline-block;
  padding-bottom: 8rpx;
}

.result-meta {
  font-size: 24rpx;
  margin-bottom: 18rpx;
}

.prompt-list {
  margin-top: 8rpx;
}

.prompt-item {
  position: relative;
}

.prompt-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e6e6f0;
  margin-bottom: 8rpx;
}

.prompt-preview {
  font-size: 24rpx;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.prompt-tags {
  margin-top: 4rpx;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.footer {
  margin-top: 60rpx;
  text-align: center;
  font-size: 22rpx;
}

.footer-text {
  font-size: 22rpx;
}
