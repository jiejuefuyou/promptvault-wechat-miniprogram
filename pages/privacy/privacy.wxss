.container { padding: 32rpx 28rpx 100rpx; }

.header { margin-bottom: 28rpx; }
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #e6e6f0;
  margin-bottom: 8rpx;
}
.subtitle { font-size: 22rpx; }

.hi-card {
  background: linear-gradient(135deg, rgba(108,75,224,0.18), rgba(192,132,252,0.08));
  border: 1rpx solid rgba(108,75,224,0.4);
  padding: 28rpx;
  margin-bottom: 32rpx;
}
.hi-text {
  font-size: 28rpx;
  color: #c084fc;
  margin-bottom: 12rpx;
}
.hi-emphasis {
  font-size: 36rpx;
  font-weight: 700;
  color: #e6e6f0;
  line-height: 1.4;
}

.section {
  margin-bottom: 36rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e6e6f0;
  margin-bottom: 14rpx;
}
.section-body {
  font-size: 28rpx;
  line-height: 1.8;
  color: #c0c0d0;
  margin-bottom: 8rpx;
}
.section-body.strong {
  color: #e6e6f0;
  font-weight: 500;
  margin-top: 12rpx;
}

/* bullet list */
.bullets {
  margin: 12rpx 0;
  padding: 0;
}
.bullet {
  position: relative;
  font-size: 28rpx;
  line-height: 1.7;
  color: #c0c0d0;
  padding-left: 36rpx;
  margin-bottom: 8rpx;
}
.bullet::before {
  content: "•";
  position: absolute;
  left: 12rpx;
  color: #6c4be0;
  font-weight: 700;
}
.bullets-x .bullet::before {
  content: "✗";
  color: #ff6b6b;
  font-weight: 700;
}

/* contact rows */
.contact-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1f1f2e;
}
.contact-row:last-child { border-bottom: 0; }
.contact-label {
  font-size: 26rpx;
  color: #8a8a9a;
  width: 140rpx;
}
.contact-value {
  font-size: 26rpx;
  color: #c084fc;
}
.contact-value-plain {
  font-size: 26rpx;
  color: #c0c0d0;
}

.footer-note {
  margin-top: 60rpx;
  font-size: 22rpx;
  text-align: center;
  line-height: 1.6;
}
