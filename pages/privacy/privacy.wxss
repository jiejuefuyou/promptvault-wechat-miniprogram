.container { padding: 32rpx 28rpx 100rpx; }

.header { margin-bottom: 28rpx; }
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #e6e6f0;
  margin-bottom: 8rpx;
}
.subtitle { font-size: 22rpx; }

.hi-card {
  background: linear-gradient(135deg, rgba(108,75,224,0.18), rgba(192,132,252,0.08));
  border: 1rpx solid rgba(108,75,224,0.4);
  padding: 28rpx;
  margin-bottom: 32rpx;
}
.hi-text {
  font-size: 28rpx;
  color: #c084fc;
  margin-bottom: 12rpx;
}
.hi-emphasis {
  font-size: 36rpx;
  font-weight: 700;
  color: #e6e6f0;
  line-height: 1.4;
}

.section {
  margin-bottom: 32rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e6e6f0;
  margin-bottom: 12rpx;
}
.section-body {
  font-size: 28rpx;
  line-height: 1.8;
  color: #c0c0d0;
}

.footer {
  margin-top: 60rpx;
  font-size: 22rpx;
  text-align: center;
  line-height: 1.6;
}
